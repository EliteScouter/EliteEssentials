$C = "../Common.ui";
$A = "EliteEssentials_AdminShared.ui";

Group {
  Anchor: (Width: 540, Height: 460);
  Background: #111820(0.98);
  LayoutMode: Top;
  Padding: (Full: 18);

  // Header
  Group {
    LayoutMode: Left;
    Anchor: (Height: 34);

    Label #PageTitle {
      Text: "Mute Management";
      FlexWeight: 1;
      Anchor: (Height: 34);
      Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
    }

    TextButton #BackButton {
      Text: "BACK";
      Anchor: (Width: 70, Height: 28);
      Style: $A.@AdminSecBtn;
    }
  }

  Group { Anchor: (Height: 2); Background: #1a2332; }
  Group { Anchor: (Height: 10); }

  // Mute Player
  Label #MuteLabel {
    Text: "MUTE A PLAYER";
    Anchor: (Height: 18);
    Style: (FontSize: 9, TextColor: #4a5568, LetterSpacing: 2);
  }

  Group { Anchor: (Height: 4); }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 38);
    Background: #1a2332(0.4);
    Padding: (Left: 10, Right: 10);

    Label { Text: "Player"; Anchor: (Width: 60, Height: 38); Style: (FontSize: 11, TextColor: #96a9be, VerticalAlignment: Center); }
    $C.@TextField #MutePlayerInput { FlexWeight: 1; PlaceholderText: "Player name..."; }
  }

  Group { Anchor: (Height: 6); }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 38);
    Background: #1a2332(0.4);
    Padding: (Left: 10, Right: 10);

    Label { Text: "Duration"; Anchor: (Width: 60, Height: 38); Style: (FontSize: 11, TextColor: #96a9be, VerticalAlignment: Center); }
    $C.@TextField #MuteDurationInput { FlexWeight: 1; PlaceholderText: "e.g. 30m, 1h, 1d, perm"; }
  }

  Group { Anchor: (Height: 6); }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 38);
    Background: #1a2332(0.4);
    Padding: (Left: 10, Right: 10);

    Label { Text: "Reason"; Anchor: (Width: 60, Height: 38); Style: (FontSize: 11, TextColor: #96a9be, VerticalAlignment: Center); }
    $C.@TextField #MuteReasonInput { FlexWeight: 1; PlaceholderText: "Reason for mute..."; }
  }

  Group { Anchor: (Height: 8); }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 34);

    TextButton #MuteButton {
      Text: "MUTE";
      Anchor: (Width: 100, Height: 30);
      Style: $A.@AdminWarnBtn;
    }
  }

  Group { Anchor: (Height: 12); }

  // Unmute
  Label #UnmuteLabel {
    Text: "UNMUTE A PLAYER";
    Anchor: (Height: 18);
    Style: (FontSize: 9, TextColor: #4a5568, LetterSpacing: 2);
  }

  Group { Anchor: (Height: 4); }

  Group {
    LayoutMode: Left;
    Anchor: (Height: 38);
    Background: #1a2332(0.4);
    Padding: (Left: 10, Right: 10);

    $C.@TextField #UnmutePlayerInput { FlexWeight: 1; PlaceholderText: "Player name to unmute..."; }

    Group { Anchor: (Width: 8); }

    TextButton #UnmuteButton {
      Text: "UNMUTE";
      Anchor: (Width: 90, Height: 30);
      Style: $A.@AdminPrimaryBtn;
    }
  }

  Group { FlexWeight: 1; }

  // Active Mutes
  Label #ActiveLabel {
    Text: "ACTIVE MUTES";
    Anchor: (Height: 18);
    Style: (FontSize: 9, TextColor: #4a5568, LetterSpacing: 2);
  }

  Group { Anchor: (Height: 4); }

  Group {
    Background: #1a2332(0.3);
    Padding: (Full: 8);
    Anchor: (Height: 50);

    Label #MuteList {
      Text: "No active mutes";
      Anchor: (Height: 40);
      Style: (FontSize: 11, TextColor: #6e7da1);
    }
  }

  Group { Anchor: (Height: 8); }

  // Footer
  Group {
    LayoutMode: Left;
    Anchor: (Height: 28);

    Label #MuteStatusMsg {
      Text: "";
      FlexWeight: 1;
      Anchor: (Height: 28);
      Style: (FontSize: 10, TextColor: #2ecc71, VerticalAlignment: Center);
    }

    TextButton #CloseButton {
      Text: "CLOSE";
      Anchor: (Width: 80, Height: 26);
      Style: $A.@AdminSecBtn;
    }
  }
}
